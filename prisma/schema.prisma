generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                    @id @default(uuid())
  email                   String                    @unique
  password                String
  name                    String
  avatar                  String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  aiGenerationLogs        AIGenerationLog[]
  contents                Content[]
  platformAccounts        PlatformAccount[]
  wechatConfigs           WechatAccountConfig[]
  weiboAppConfigs         WeiboAppConfig[]
  platformPublishConfigs  PlatformPublishConfig[]
  contentRequests         ContentGenerationRequest[]
  publishJobs             PublishJob[]
  engagementDailySnapshots UserEngagementDailySnapshot[]

  @@index([email])
}

/// 用户级互动数据日快照（刷新概览时写入，用于趋势图；当日多次刷新会更新同一天记录）
model UserEngagementDailySnapshot {
  id           String   @id @default(uuid())
  userId       String
  /// UTC 当日 0 点，仅按日期区分
  day          DateTime
  views        Int      @default(0)
  comments     Int      @default(0)
  likes        Int      @default(0)
  shares       Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@index([userId, day])
  @@map("user_engagement_daily_snapshots")
}

model PlatformAccount {
  id                    String                @id @default(uuid())
  userId                String
  platform              Platform
  platformUserId        String
  platformUsername      String
  accessToken           String
  refreshToken          String?
  tokenExpiry           DateTime?
  isConnected           Boolean               @default(true)
  weiboAppConfigId      String?
  wechatAccountConfigId String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  analytics             Analytics[]
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  weiboAppConfig        WeiboAppConfig?       @relation(fields: [weiboAppConfigId], references: [id], onDelete: SetNull)
  wechatAccountConfig   WechatAccountConfig?  @relation(fields: [wechatAccountConfigId], references: [id], onDelete: Cascade)
  contentPlatforms      ContentPlatform[]
  publishJobs           PublishJob[]

  @@unique([userId, platform, platformUserId])
  @@index([userId])
  @@index([weiboAppConfigId])
  @@index([wechatAccountConfigId])
}

model PublishJob {
  id                String           @id @default(uuid())
  userId            String
  platformAccountId String
  contentId         String?
  payload           Json
  status            PublishJobStatus @default(QUEUED)
  errorMessage      String?
  platformPostId    String?
  publishedUrl      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformAccount   PlatformAccount  @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platformAccountId])
  @@index([status])
  @@map("publish_jobs")
}

model WeiboAppConfig {
  id                String            @id @default(uuid())
  userId            String
  appId             String
  appSecret         String
  appName           String?
  callbackUrl       String
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformAccounts  PlatformAccount[]

  @@unique([userId, appId])
  @@index([userId])
  @@map("weibo_app_configs")
}

model Content {
  id               String            @id @default(uuid())
  userId           String
  title            String
  content          String
  coverImage       String?
  images           String[]
  contentType      String?           // 'image-text' | 'article' - 用于判断编辑器类型
  status           ContentStatus     @default(DRAFT)
  aiGenerated      Boolean           @default(false)
  aiModel          String?
  scheduledAt      DateTime?
  publishedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentPlatforms ContentPlatform[]

  @@index([userId, status])
  @@index([scheduledAt])
}

model ContentPlatform {
  id                String               @id @default(uuid())
  contentId         String
  platformAccountId String?
  wechatConfigId    String?
  /// 微信数据统计用 msgid，格式 msg_data_id_图文索引（如 2247490098_1），与 getarticleread / getarticletotal 一致
  wechatDatacubeMsgid String?
  platformContentId String?
  /// 微博时间线帖 mid，用于 ajax/statuses/show；头条时往往与 platformContentId（object_id 等）不同
  weiboTimelineMid  String?
  /// 该平台侧实际发布完成时间（用于数据统计对齐；与 Content.publishedAt 可不同）
  platformPublishedAt DateTime?
  publishStatus     PublishStatus        @default(PENDING)
  errorMessage      String?
  publishedUrl      String?
  createdAt         DateTime             @default(now())
  analytics         Analytics?
  content           Content              @relation(fields: [contentId], references: [id], onDelete: Cascade)
  platformAccount   PlatformAccount?     @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)
  wechatConfig      WechatAccountConfig? @relation(fields: [wechatConfigId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([platformAccountId])
  @@index([wechatConfigId])
  @@map("content_platforms")
}

model Analytics {
  id                String          @id @default(uuid())
  contentPlatformId String          @unique
  platformAccountId String
  date              DateTime
  views             Int             @default(0)
  likes             Int             @default(0)
  comments          Int             @default(0)
  shares            Int             @default(0)
  followers         Int             @default(0)
  engagementRate    Float           @default(0)
  createdAt         DateTime        @default(now())
  contentPlatform   ContentPlatform @relation(fields: [contentPlatformId], references: [id], onDelete: Cascade)
  platformAccount   PlatformAccount @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)

  @@index([platformAccountId, date])
}

model AIGenerationLog {
  id               String           @id @default(uuid())
  userId           String
  model            String
  prompt           String
  generatedContent String
  type             AIGenerationType
  tokensUsed       Int?
  duration         Int?
  createdAt        DateTime         @default(now())
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model WechatAccountConfig {
  id               String             @id @default(uuid())
  userId           String
  appId            String
  appSecret        String
  accountName      String?
  accountType      String?
  subjectType      String?
  canPublish       Boolean            @default(false)
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  contentPlatforms ContentPlatform[]
  platformAccounts PlatformAccount[]
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, appId])
  @@index([userId])
  @@map("wechat_account_configs")
}

model PlatformPublishConfig {
  id          String   @id @default(uuid())
  userId      String
  platform    String
  configName  String
  description String?  @db.VarChar(500)
  configData  Json
  isDefault   Boolean  @default(false)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, configName], name: "unique_user_platform_config")
  @@index([userId, platform], name: "idx_user_platform")
  @@map("platform_publish_configs")
}

enum Platform {
  WECHAT
  WEIBO
  ZHIHU
  DOUYIN
  XIAOHONGSHU
}

enum ContentStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum PublishStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PublishJobStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

enum AIGenerationType {
  TEXT
  IMAGE
}

enum ContentGenerationStatus {
  PENDING
  SEARCHING
  CREATING
  GENERATING_IMAGE
  COMPLETED
  FAILED
}

enum WorkflowExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum StepExecutionStatus {
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
  RETRYING
}

model ContentGenerationRequest {
  id                String                     @id @default(cuid())
  userId            String
  prompt            String                     @db.Text
  platform          Platform?
  style             String?                    @db.Text
  status            ContentGenerationStatus    @default(PENDING)
  content           GeneratedContent?
  workflowExecution WorkflowExecution?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  user              User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model GeneratedContent {
  id            String                     @id @default(cuid())
  requestId     String                     @unique
  title         String?                    @db.Text
  body          String                     @db.Text
  tags          String[]
  imageUrl      String?
  imagePrompt   String?                    @db.Text
  platform      Platform?
  searchResults Json?
  rating        Int?
  feedback      String?                    @db.Text
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  request       ContentGenerationRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([createdAt])
}

model WorkflowExecution {
  id           String                   @id @default(cuid())
  requestId    String                   @unique
  workflowId   String
  status       WorkflowExecutionStatus  @default(RUNNING)
  currentStep  String?
  input        Json
  output       Json?
  error        String?                  @db.Text
  errorStep    String?
  startedAt    DateTime                 @default(now())
  completedAt  DateTime?
  duration     Int?
  steps        WorkflowStepExecution[]
  request      ContentGenerationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([status])
  @@index([workflowId])
}

model WorkflowStepExecution {
  id          String               @id @default(cuid())
  executionId String
  stepId      String
  stepName    String
  status      StepExecutionStatus  @default(RUNNING)
  retryCount  Int                  @default(0)
  input       Json?
  output      Json?
  error       String?              @db.Text
  startedAt   DateTime             @default(now())
  completedAt DateTime?
  duration    Int?
  execution   WorkflowExecution    @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([stepId])
}
