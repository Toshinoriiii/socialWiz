# Copy to .env.local and fill values (never commit secrets)

DATABASE_URL="postgresql://user:password@localhost:5432/socialwiz"
JWT_SECRET="change-me"

# Optional: show Weibo **开放平台 OAuth** entry in accounts UI (default off; main path is browser session)
NEXT_PUBLIC_ENABLE_WEIBO_OAUTH_UI=false

# Weibo OAuth / API (compat path when using official adapter)
# WEIBO_APP_KEY=
# WEIBO_APP_SECRET=
# WEIBO_REDIRECT_URI=

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 服务端拉取本机 public 图片（如 /content-images）时使用；默认同 NEXT_PUBLIC_BASE_URL
# INTERNAL_MEDIA_BASE_URL=http://127.0.0.1:3000
